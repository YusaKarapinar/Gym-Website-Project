@model IEnumerable<GymViewModel>

@{
    ViewData["Title"] = "Gym Listesi";
}

<div class="text-center py-4 mb-4" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
    <div class="container text-white">
        <h1 class="display-5 fw-bold mb-2">
            <i class="fas fa-building"></i> Spor Salonları
        </h1>
        <p class="lead mb-3">Tüm spor salonlarını yönetin</p>
    </div>
</div>

<div class="container">
    <div class="mb-4">
        <a asp-action="Create" class="btn btn-primary btn-lg">
            <i class="fas fa-plus"></i> Yeni Salon Ekle
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th><i class="fas fa-tag"></i> İsim</th>
                        <th><i class="fas fa-map-marker-alt"></i> Adres</th>
                        <th><i class="fas fa-phone"></i> Telefon</th>
                        <th><i class="fas fa-check-circle"></i> Aktif</th>
                        <th class="text-center"><i class="fas fa-cog"></i> İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var gym in Model)
                    {
                        <tr>
                            <td class="fw-bold">@gym.Name</td>
                            <td>@gym.Address</td>
                            <td>@gym.PhoneNumber</td>
                            <td>
                                @if (gym.IsActive)
                                {
                                    <span class="badge bg-success">Evet</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Hayır</span>
                                }
                            </td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@gym.GymId" class="btn btn-sm btn-info">
                                    <i class="fas fa-eye"></i> Detay
                                </a>
                                <a asp-action="Edit" asp-route-id="@gym.GymId" class="btn btn-sm btn-warning">
                                    <i class="fas fa-edit"></i> Düzenle
                                </a>
                                <a asp-action="Delete" asp-route-id="@gym.GymId" class="btn btn-sm btn-danger">
                                    <i class="fas fa-trash"></i> Sil
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
