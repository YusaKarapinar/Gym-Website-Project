@model ServiceViewModel

@{
    ViewData["Title"] = "Hizmet Detayı";
}

<h1>Hizmet Detayı</h1>

<div>
    <h4>@Model.Name</h4>
    
    <dl>
        <dt>Hizmet Adı</dt>
        <dd>@Model.Name</dd>

        <dt>Açıklama</dt>
        <dd>@Model.Description</dd>

        <dt>Hizmet Türü</dt>
        <dd>@Model.ServiceType</dd>

        <dt>Süre</dt>
        <dd>@Model.Duration.ToString(@"hh\:mm")</dd>

        <dt>Fiyat</dt>
        <dd>@Model.Price.ToString("C2")</dd>

        <dt>Salon</dt>
        <dd>@Model.GymName</dd>

        <dt>Durum</dt>
        <dd>@(Model.IsActive ? "Aktif" : "Pasif")</dd>
    </dl>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model.ServiceId" class="btn btn-warning">Düzenle</a>
    <a asp-action="Index" class="btn btn-secondary">Listeye Dön</a>
</div>
