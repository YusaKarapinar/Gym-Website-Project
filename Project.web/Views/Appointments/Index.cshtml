@model IEnumerable<AppointmentViewModel>

@{
    ViewData["Title"] = "Randevu Listesi";
}

<div class="text-center py-4 mb-4" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
    <div class="container text-white">
        <h1 class="display-5 fw-bold mb-2">
            <i class="fas fa-calendar-alt"></i> Randevular
        </h1>
        <p class="lead mb-3">Tüm randevuları görüntüleyin ve yönetin</p>
    </div>
</div>

<div class="container">
    <div class="mb-4">
        <a asp-action="Create" class="btn btn-primary btn-lg">
            <i class="fas fa-plus"></i> Yeni Randevu Oluştur
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th><i class="fas fa-calendar"></i> Tarih</th>
                        <th><i class="fas fa-clock"></i> Saat</th>
                        <th><i class="fas fa-user"></i> Üye</th>
                        <th><i class="fas fa-user-tie"></i> Eğitmen</th>
                        <th><i class="fas fa-concierge-bell"></i> Hizmet</th>
                        <th><i class="fas fa-info-circle"></i> Durum</th>
                        <th><i class="fas fa-dollar-sign"></i> Fiyat</th>
                        <th class="text-center"><i class="fas fa-cog"></i> İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var appointment in Model)
                        {
                            <tr>
                                <td>@appointment.Date.ToString("dd.MM.yyyy")</td>
                                <td>@appointment.Time.ToString(@"hh\:mm")</td>
                                <td>@appointment.UserName</td>
                                <td>@appointment.TrainerName</td>
                                <td>@appointment.ServiceName</td>
                                <td>
                                    @switch (appointment.Status)
                                    {
                                        case "Pending":
                                            <span class="badge bg-warning">Beklemede</span>
                                            break;
                                        case "Approved":
                                            <span class="badge bg-success">Onaylandı</span>
                                            break;
                                        case "Rejected":
                                            <span class="badge bg-danger">Reddedildi</span>
                                            break;
                                        case "Canceled":
                                            <span class="badge bg-secondary">İptal</span>
                                            break;
                                        case "Completed":
                                            <span class="badge bg-info">Tamamlandı</span>
                                            break;
                                        default:
                                            <span class="badge bg-light text-dark">@appointment.Status</span>
                                            break;
                                    }
                                </td>
                                <td>@appointment.Price.ToString("C2")</td>
                                <td class="text-center">
                                    <form asp-action="Delete" asp-route-id="@appointment.AppointmentId" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Bu randevuyu silmek istediğinize emin misiniz?')">
                                            <i class="fas fa-trash"></i> Sil
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center py-4 text-muted">
                                <i class="fas fa-calendar-times fa-3x mb-3"></i>
                                <p>Henüz randevu bulunmamaktadır.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
